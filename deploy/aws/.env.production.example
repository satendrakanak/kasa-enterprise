# Copy this file to .env.production on the AWS EC2 instance.
# Never commit the real .env.production file.

ENTERPRISE_DOMAIN=enterprise.example.com
ENTERPRISE_API_DOMAIN=enterprise-api.example.com
NEXT_PUBLIC_APP_URL=https://enterprise.example.com
NEXT_PUBLIC_API_BASE_URL=http://server:8000
APP_URL=https://enterprise-api.example.com
FRONT_END_URL=https://enterprise.example.com
API_VERSION=0.1.1

CLIENT_PORT=3100
SERVER_PORT=8100

POSTGRES_USER=kasa_enterprise
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_DB=kasa_enterprise
POSTGRES_VOLUME_NAME=kasa-enterprise-live_postgres_data

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=kasa_enterprise
DATABASE_PASSWORD=replace-with-long-random-password
DATABASE_NAME=kasa_enterprise
DATABASE_SYNC=false
DATABASE_AUTO_LOAD=true

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_VOLUME_NAME=kasa-enterprise-live_redis_data

JWT_SECRET=replace-with-long-random-jwt-secret
JWT_TOKEN_AUDIENCE=https://enterprise.example.com
JWT_TOKEN_ISSUER=https://enterprise-api.example.com
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400
APP_ENCRYPTION_KEY=replace-with-long-random-encryption-key

LICENSE_PORTAL_URL=https://license.example.com
LICENSE_PRODUCT_SLUG=kasa-enterprise
