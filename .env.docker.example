# Copy to .env.docker for local Docker development.

# Public ports on your machine
CLIENT_PORT=3000
SERVER_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Local Docker database
POSTGRES_USER=codewithkasa
POSTGRES_PASSWORD=change-me-local
POSTGRES_DB=kasa_enterprise

# Server app
NODE_ENV=development
APP_URL=http://localhost:8000
APP_PORT=8000
FRONT_END_URL=http://localhost:3000
API_VERSION=0.1.1

# NestJS database settings
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=codewithkasa
DATABASE_PASSWORD=change-me-local
DATABASE_NAME=kasa_enterprise
DATABASE_SYNC=true
DATABASE_AUTO_LOAD=true

# Auth
JWT_SECRET=change-me-local-jwt-secret
JWT_TOKEN_AUDIENCE=http://localhost:3000
JWT_TOKEN_ISSUER=http://localhost:8000
JWT_ACCESS_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=86400

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Encryption
APP_ENCRYPTION_KEY=change-me-local-encryption-key
INSTALLER_LICENSE_HASH=

# Client public runtime
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://server:8000
